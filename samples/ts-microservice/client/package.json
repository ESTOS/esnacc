{
	"name": "microservice_client",
	"version": "1.0.1",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"pnpm": ">=10",
		"node": ">=22"
	},
	"description": "estos microservice client example",
	"private": true,
	"main": "src/sampleclient.js",
	"scripts": {
		"start": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"check": "npx madge --circular --extensions ts ./",
		"lint": "dprint fmt && eslint --cache --fix src/**/*.{js,ts,tsx}",
		"lintclear": "del /s .eslintcache",
		"relint": "run-s lintclear lint",
		"depcheck": "npx depcheck",
		"preinstall": "node check-pm.js"
	},
	"browserslist": [
		"last 3 version",
		">0.5%",
		"not dead",
		"not IE > 0",
		"not op_mini all",
		"not op_mob > 0"
	],
	"dependencies": {
		"@estos/asn1ts": "^3.2.3",
		"@types/ws": "^8.18.1",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@estos/config-eslint": "^1.0.8",
		"@types/node": "^25.5.0",
		"dprint": "^0.53.0",
		"eslint": "^10.1.0",
		"npm-run-all": "^4.1.5",
		"vite": "^8.0.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"dprint",
			"esbuild"
		]
	}
}
