{
	"name": "microservice_server",
	"version": "1.0.1",
	"type": "module",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"pnpm": ">=11",
		"node": ">=24"
	},
	"description": "estos microservice server example",
	"private": true,
	"scripts": {
		"check": "npx madge --circular --extensions ts --exclude \"\\.d\\.ts$|globals|dist\" ./",
		"build": "tsc -p .",
		"clean": "npx rimraf dist",
		"lint": "dprint fmt && oxlint",
		"start": "node --trace-warnings index.js",
		"start:debug": "node --inspect index.js --runInBand",
		"start:watch": "tsc-watch --onSuccess \"node index.js\"",
		"start:debugwatch": "tsc-watch --onSuccess \"node --inspect index.js --runInBand\"",
		"depcheck": "npx depcheck",
		"preinstall": "node check-pm.js"
	},
	"repository": {
		"type": "git",
		"url": ""
	},
	"lint-staged": {
		"src/**/*.{ts,tsx,json,jsonc}": [
			"dprint fmt",
			"oxlint --fix"
		]
	},
	"license": "UNLICENSED",
	"dependencies": {
		"@estos/asn1ts": "^3.2.3",
		"cors": "^2.8.6",
		"cross-env": "^10.1.0",
		"date-fns": "^4.1.0",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"typescript": "^6.0.3",
		"ucconfig": "github:estos/ucconfig#0.0/0.0.3",
		"uclogger": "github:estos/uclogger#0.0/0.0.21",
		"uuid": "^13.0.0",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^26.0.1",
		"@types/ws": "^8.18.1",
		"axios": "^1.18.1",
		"dprint": "^0.55.1",
		"lint-staged": "^17.0.8",
		"npm-run-all": "^4.1.5",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0"
	}
}
