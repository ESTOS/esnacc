{
	"name": "microservice_client",
	"version": "1.0.1",
	"type": "module",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"pnpm": ">=11",
		"node": ">=24"
	},
	"description": "estos microservice client example",
	"private": true,
	"main": "src/sampleclient.js",
	"scripts": {
		"start": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"check": "npx madge --circular --extensions ts ./",
		"lint": "dprint fmt && oxlint",
		"depcheck": "npx depcheck",
		"preinstall": "node check-pm.js"
	},
	"browserslist": [
		"last 3 version",
		">0.5%",
		"not dead",
		"not IE > 0",
		"not op_mini all",
		"not op_mob > 0"
	],
	"dependencies": {
		"@estos/asn1ts": "^3.2.3",
		"@types/ws": "^8.18.1",
		"ts-loader": "^9.6.2",
		"typescript": "^6.0.3",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"dprint": "^0.55.1",
		"npm-run-all": "^4.1.5",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"vite": "^8.1.0"
	}
}
